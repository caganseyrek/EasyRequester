{
	"name": "easy-requester",
	"version": "2.2.0",
	"description": "A custom and flexible HTTP requester",
	"main": "dist/index.js",
	"type": "module",
	"keywords": [
		"typescript",
		"http-requester",
		"fetch-api"
	],
	"author": "Çağan Seyrek",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/caganseyrek/EasyRequester/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/caganseyrek/EasyRequester.git"
	},
	"homepage": "https://github.com/caganseyrek/EasyRequester",
	"lint-staged": {
		"src/**/*.ts": [
			"prettier --write",
			"eslint . --report-unused-disable-directives --max-warnings 0"
		],
		"tests/**/*.ts": [
			"prettier --write",
			"eslint . --report-unused-disable-directives --max-warnings 0"
		]
	},
	"scripts": {
		"build": "tsc -b",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0",
		"test": "jest",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^9.17.0",
		"@jest/globals": "^29.7.0",
		"@types/node": "^22.10.2",
		"eslint": "^9.17.0",
		"globals": "^15.14.0",
		"husky": "^9.1.7",
		"jest": "^29.7.0",
		"lint-staged": "^15.3.0",
		"ts-jest": "^29.2.5",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.19.0"
	}
}
